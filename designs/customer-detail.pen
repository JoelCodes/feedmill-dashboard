{
  "version": "2.8",
  "children": [
    {
      "type": "frame",
      "id": "cust-detail-root",
      "x": 0,
      "y": 0,
      "name": "Customer Detail Page",
      "clip": true,
      "width": 1920,
      "height": 1200,
      "fill": "#f8f9faff",
