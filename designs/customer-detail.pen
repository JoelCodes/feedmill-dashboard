              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "logo-icon-detail",
                  "name": "Logo Icon",
                  "width": 32,
                  "height": 32,
                  "fill": "#4fd1c5ff",
                  "cornerRadius": 8,
                  "layout": "none"
                },
                {
                  "type": "text",
