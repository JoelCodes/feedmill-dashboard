{
  "name": "feedmill-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' jest",
    "test:watch": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:concurrent-race": "tsx --env-file=.env.local --import ./scripts/_server-only-shim.mjs scripts/test-concurrent-transition.ts",
    "test:e2e:debug": "playwright test --debug",
    "test:xlsx-import": "tsx --env-file=.env.local --import ./scripts/_server-only-shim.mjs scripts/test-xlsx-import.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.3",
    "@neondatabase/serverless": "1.1.0",
    "@radix-ui/react-dialog": "1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "2.8.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "read-excel-file": "9.0.9",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clerk/testing": "^2.0.27",
    "@clerk/types": "^4.101.23",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
